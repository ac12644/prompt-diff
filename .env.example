# Copy this file to .env and fill in the keys you need.
# Only set the providers you'll actually use; the others can stay blank.

# OpenAI: required for gpt-*, o1-*, o3-*, o4-* models
OPENAI_API_KEY=

# Anthropic: required for claude-* models
ANTHROPIC_API_KEY=

# Google: required for gemini-* models (GOOGLE_API_KEY is accepted as a fallback)
GEMINI_API_KEY=

# Optional: override the response cache directory (default .promptdiff-cache)
# PROMPTDIFF_CACHE_DIR=.promptdiff-cache
